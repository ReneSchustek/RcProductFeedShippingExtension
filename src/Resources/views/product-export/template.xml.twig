<item>
    <g:id>{{ product.id|e }}</g:id>
    <g:title>{{ product.name|e }}</g:title>
    <g:description>{{ product.description|striptags|e }}</g:description>
    <g:link>{{ seoUrl('frontend.detail.page', {productId: product.id})|e }}</g:link>
    <g:image_link>{{ product.cover.media.url|e }}</g:image_link>
    <g:availability>{{ product.availableStock > 0 ? 'in stock' : 'out of stock' }}</g:availability>
    <g:price>{{ product.calculatedPrice.unitPrice|number_format(2, '.', '') }} EUR</g:price>
    <g:brand>{{ (product.manufacturer.name ?? '')|e }}</g:brand>
    {% if rcShipping.get(product.id, 'DE') is not null %}
    <g:shipping>
        <g:country>DE</g:country>
        <g:service>Standard</g:service>
        <g:price>{{ rcShipping.get(product.id, 'DE') | number_format(2, '.', '') }} EUR</g:price>
    </g:shipping>
    {% endif %}
    {% if rcShipping.get(product.id, 'AT') is not null %}
    <g:shipping>
        <g:country>AT</g:country>
        <g:service>Standard</g:service>
        <g:price>{{ rcShipping.get(product.id, 'AT') | number_format(2, '.', '') }} EUR</g:price>
    </g:shipping>
    {% endif %}
    {% if rcShipping.get(product.id, 'CH') is not null %}
    <g:shipping>
        <g:country>CH</g:country>
        <g:service>Standard</g:service>
        <g:price>{{ rcShipping.get(product.id, 'CH') | number_format(2, '.', '') }} EUR</g:price>
    </g:shipping>
    {% endif %}
</item>

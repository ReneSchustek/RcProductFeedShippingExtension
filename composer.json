{
    "name": "ruhrcoder/rc-product-feed-shipping-extension",
    "description": "Extends Shopware product feeds with calculated shipping costs per country",
    "type": "shopware-platform-plugin",
    "license": "MIT",
    "version": "1.0.0",
    "authors": [
        {
            "name": "Ruhrcoder",
            "homepage": "https://ruhrcoder.de"
        }
    ],
    "require": {
        "shopware/core": "~6.7.0 || ~6.8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0 || ^11.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "RuhrCoder\\RcProductFeedShippingExtension\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RuhrCoder\\RcProductFeedShippingExtension\\Tests\\": "Tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "phpstan": "vendor/bin/phpstan analyse --memory-limit=512M",
        "cs-fix": "vendor/bin/php-cs-fixer fix",
        "cs-check": "vendor/bin/php-cs-fixer fix --dry-run --diff",
        "quality": [
            "@cs-check",
            "@phpstan",
            "@test"
        ]
    },
    "extra": {
        "shopware-plugin-class": "RuhrCoder\\RcProductFeedShippingExtension\\RcProductFeedShippingExtension",
        "label": {
            "de-DE": "Ruhrcoder - Produktfeed Versandkostenerweiterung",
            "en-GB": "Ruhrcoder - Product Feed Shipping Extension"
        },
        "description": {
            "de-DE": "Erweitert Produktfeeds um länderspezifisch berechnete Versandkosten im Google Shopping Format.",
            "en-GB": "Extends product feeds with country-specific calculated shipping costs in Google Shopping format."
        }
    }
}
